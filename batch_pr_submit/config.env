# Batch PR Submit Configuration

# Maximum parallel jobs (each job needs one exclusive GPU)
MAX_PARALLEL=1

# Operator list file path
OP_LIST="/workspace/batch_pr_submit/operators_minimax_20260604_pending.txt"

# FlagGems repo directory (source repo, not modified during parallel runs)
REPO_DIR="/workspace/FlagGems_minimax_2_7"

# Skill scripts directory
SCRIPTS_DIR="/workspace/.claude/skills/flaggems-pr-submit/scripts"

# GitHub token. Export GH_TOKEN before starting the batch.
GH_TOKEN="${GH_TOKEN:-}"

# Log directory (JSON records + text logs per run)
LOG_DIR="/workspace/batch_pr_submit/logs"

# Worktree base directory (each operator gets a temporary worktree here)
WORKTREE_BASE_DIR="/tmp/flaggems_worktrees"
