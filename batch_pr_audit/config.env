# Batch PR audit defaults.

REPO="flagos-ai/FlagGems"
REPO_DIR="/workspace/FlagGems_minimax_2_7"
SKILL_DIR="/workspace/.claude/skills/flaggems-pr-submit"
REPORT_DIR="/workspace/batch_pr_audit/reports"
CLAUDE_BIN="claude"
MODEL="deepseek-v4-pro"
PERMISSION_MODE="acceptEdits"
MAX_WORKERS=4
TIMEOUT_MINUTES=25
ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-}"
ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-}"
